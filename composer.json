{
    "name": "yezzmedia/laravel-user-support",
    "version": "0.1.0",
    "description": "User-facing support ticket system with public contact form, legal pages, and operator-managed conversations for the Yezz Media Laravel platform.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Yezz Media",
            "email": "info@yezzmedia.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^13.0",
        "illuminate/support": "^13.0",
        "livewire/livewire": "^4.1",
        "spatie/laravel-package-tools": "^1.93",
        "yezzmedia/laravel-account": "^0.1",
        "yezzmedia/laravel-dashboard": "^0.1",
        "yezzmedia/laravel-foundation": "^0.1"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.29",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "YezzMedia\\UserSupport\\": "src/",
            "YezzMedia\\UserSupport\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "YezzMedia\\UserSupport\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "YezzMedia\\UserSupport\\UserSupportServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=512M",
        "format": "vendor/bin/pint --format agent"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
